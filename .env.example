# eComBot Capstone — Environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# LLM (required)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Session backend
# Options: memory | redis | database (default: memory)
SESSION_BACKEND=memory

# PostgreSQL (required for database session backend)
PG_HOST=localhost
PG_PORT=5432
PG_DB=ecombot
PG_USER=ecombot
PG_PASSWORD=pg_secret

# Redis (required for redis session backend)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_SESSION_TTL=3600

# ChromaDB / RAG
# Vector store persist directory (relative to project root, default: data/chroma_db)
CHROMA_PERSIST_DIR=data/chroma_db
# ChromaDB collection name
CHROMA_COLLECTION=ecombot_kb
# Embedding model — uses OPENROUTER_API_KEY above (same key, OpenAI-compatible endpoint)
EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small
# VECTOR_BACKEND: disk (default, persists to CHROMA_PERSIST_DIR) | memory (ephemeral)
VECTOR_BACKEND=disk
# Disable ChromaDB telemetry (suppresses posthog noise in logs)
ANONYMIZED_TELEMETRY=False

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=ecombot-capstone

# LiteLLM routing
# fast-faq route: lightweight model for simple queries
FAST_MODEL=openrouter/google/gemini-2.5-flash
# deep-support route: stronger model for complex queries
DEEP_MODEL=openrouter/google/gemini-2.5-pro
# cross-provider fallback
BACKUP_MODEL=openrouter/openai/gpt-4o-mini

# FastMCP servers
ORDERS_SERVER_HOST=127.0.0.1
ORDERS_SERVER_PORT=8766
# INVENTORY_SEARCH_DELAY_SECONDS=0
# INVENTORY_TOOL_TIMEOUT_SECONDS=5

# Voice interface
# STT model for OpenRouter speech-to-text
# OPENROUTER_STT_MODEL=google/gemini-2.5-flash
# TTS model for OpenRouter text-to-speech
# OPENROUTER_TTS_MODEL=openai/gpt-audio
# OPENROUTER_TTS_VOICE=alloy
# Wall-clock deadline for TTS synthesis (seconds)
# OPENROUTER_TTS_DEADLINE=45

# OPENROUTER_TTS_VOICE=alloy
# Wall-clock deadline for TTS synthesis (seconds)
# OPENROUTER_TTS_DEADLINE=45

# MCP server toggle
# false (default): Chainlit/demo run without a separate MCP server process
# true: enables FastMCP orders+inventory servers (requires orders_server.py running)
USE_MCP=false
